---
import BlogCard from "@/components/BlogCard.astro"
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
import { getPosts } from "@/lib/content"

const posts = (await getPosts()).slice(0, 3)
---

<Layout>
  <MetaPage slot="head" />
  <main class="home">
    <section class="hero">
      <p class="eyebrow">Security notes · writeups · research</p>
      <h1>Hi, I’m tr3m0x.</h1>
      <p class="intro">
        I’m a final-year ICT Engineering student and pentester focused on practical web
        security, Linux exploitation, and useful notes.
      </p>
      <div class="actions">
        <a href="/about">About me</a>
        <a href="/blog">Read the blog</a>
      </div>
    </section>

    <section class="latest-posts">
      <div class="section-heading">
        <h2>Latest posts</h2>
        <a href="/blog">See all posts</a>
      </div>
      <ul>
        {posts.map((post) => <BlogCard post={post} />)}
      </ul>
    </section>
  </main>
</Layout>

<style>
  .home {
    display: grid;
    gap: var(--space-l);
  }

  .hero {
    display: grid;
    gap: var(--space-xs);
    max-inline-size: 45rem;
  }

  .eyebrow {
    color: var(--muted-foreground);
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    font-size: var(--step-3);
    line-height: calc(var(--leading-offset) + 1em);
    font-weight: var(--font-weight-medium);
    color: var(--foreground);
    margin: 0;
  }

  .intro {
    font-size: var(--step-0);
    color: var(--muted-foreground);
    margin: 0;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs);
    margin-block-start: var(--space-2xs);

    a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.7rem 1rem;
      border: 1px solid var(--border);
      border-radius: var(--radius-full);
      color: var(--foreground);
      text-decoration: none;
      transition: background-color 160ms ease, border-color 160ms ease;

      &:hover {
        background-color: var(--muted);
        border-color: var(--foreground);
      }
    }
  }

  .latest-posts {
    display: grid;
    gap: var(--space-xs);
  }

  .section-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s);

    h2 {
      font-size: var(--step-1);
      font-weight: var(--font-weight-medium);
      color: var(--foreground);
      margin: 0;
    }

    a {
      color: var(--muted-foreground);
      text-decoration: none;

      &:hover {
        color: var(--foreground);
      }
    }
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    padding: 0;
    margin: 0;
    list-style: none;
  }
</style>
